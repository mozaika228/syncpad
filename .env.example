# Server runtime configuration
PORT=8080
WS_PATH=/

# Security / tenancy
RELAY_AUTH_TOKEN=
TENANT_TOKENS_JSON={}
ALLOWED_ORIGINS=http://localhost:5173

# Optional multi-node bus
RELAY_REDIS_URL=
RELAY_REDIS_CHANNEL_PREFIX=syncpad:room
RELAY_REDIS_SEQ_PREFIX=syncpad:seq
NODE_ID=

# Capacity limits
MAX_HISTORY=50000
MAX_ROOM_CLIENTS=200
MAX_ROOMS_PER_TENANT=500
MAX_CLIENTS_PER_TENANT=2000
MAX_MESSAGE_BYTES=131072
MAX_BUFFERED_BYTES=2097152
MAX_OPS_PER_SECOND_PER_SOCKET=400
MAX_BYTES_PER_SECOND_PER_SOCKET=524288

# Reliability
HEARTBEAT_INTERVAL_MS=30000
ROOM_IDLE_TTL_MS=600000
ROOM_GC_INTERVAL_MS=60000
